# Normalize line endings: LF in the repo for text, CRLF only for Windows scripts.
* text=auto eol=lf

*.bat text eol=crlf
*.ps1 text eol=crlf

# Treat common binary assets as binary.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.ttf binary
*.otf binary
*.woff binary
*.woff2 binary
*.jar binary
*.keystore binary
*.jks binary
