<?xml version="1.0" encoding="UTF-8"?>
<!--
  WiX (v4/v5 schema) source for the Markdown Studio Windows .msi.
  Built by the release workflow:
    wix build tool/windows_installer.wxs -ext WixToolset.UI.wixext -arch x64
      -d Version=1.0.1 -d SourceDir=...\Release -d LicenseRtf=...\license.rtf
      -d IconPath=...\app_icon.ico -o dist\markdown-studio-vX-windows-x64.msi

  The UpgradeCode is the product's permanent identity: it must NEVER change,
  so each release's MSI upgrades the previous install in place
  (MajorUpgrade) instead of installing side by side.
-->
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:ui="http://wixtoolset.org/schemas/v4/wxs/ui">
  <Package Name="Markdown Studio"
           Manufacturer="Markdown Studio"
           Version="$(var.Version)"
           UpgradeCode="d4a5c1f2-7b3e-4a86-9d2c-1e8f0b6a7c53"
           Scope="perMachine"
           Compressed="yes">

    <MajorUpgrade DowngradeErrorMessage="A newer version of Markdown Studio is already installed." />
    <MediaTemplate EmbedCab="yes" />

    <!-- Add/Remove Programs metadata. -->
    <Icon Id="AppIcon.ico" SourceFile="$(var.IconPath)" />
    <Property Id="ARPPRODUCTICON" Value="AppIcon.ico" />
    <Property Id="ARPURLINFOABOUT" Value="https://github.com/TheSaltyKorean/md" />
    <Property Id="ARPHELPLINK" Value="https://github.com/TheSaltyKorean/md/issues" />

    <!-- Minimal wizard: welcome + license + install. -->
    <ui:WixUI Id="WixUI_Minimal" />
    <WixVariable Id="WixUILicenseRtf" Value="$(var.LicenseRtf)" />

    <!-- The whole Flutter Release bundle (exe + data/ + DLLs), harvested
         recursively at build time. -->
    <StandardDirectory Id="ProgramFiles64Folder">
      <Directory Id="INSTALLFOLDER" Name="Markdown Studio">
        <Files Include="$(var.SourceDir)\**" />
      </Directory>
    </StandardDirectory>

    <!-- Start-Menu shortcut. The HKCU registry value is the component's
         KeyPath (shortcuts cannot be key paths); it also marks the install
         for the per-user shortcut cleanup on uninstall. -->
    <StandardDirectory Id="ProgramMenuFolder">
      <Component Id="StartMenuShortcut" Guid="8e2f6c1a-0d4b-4f7e-a5c3-2b9d8e0f1a64">
        <Shortcut Id="StartMenuShortcutFile"
                  Name="Markdown Studio"
                  Description="Markdown viewer, WYSIWYG editor and PDF/print studio"
                  Target="[INSTALLFOLDER]markdown_studio.exe"
                  WorkingDirectory="INSTALLFOLDER" />
        <RegistryValue Root="HKCU"
                       Key="Software\MarkdownStudio\Installer"
                       Name="StartMenuShortcut"
                       Type="integer"
                       Value="1"
                       KeyPath="yes" />
      </Component>
    </StandardDirectory>
  </Package>
</Wix>
