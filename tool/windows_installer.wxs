<?xml version="1.0" encoding="UTF-8"?>
<!--
  WiX (v4/v5 schema) source for the Markdown Studio Windows .msi.
  Built by the release workflow:
    wix build tool/windows_installer.wxs -ext WixToolset.UI.wixext -arch x64
      -d Version=1.0.1 -d SourceDir=...\Release -d LicenseRtf=...\license.rtf
      -d IconPath=...\app_icon.ico -o dist\markdown-studio-vX-windows-x64.msi

  The UpgradeCode is the product's permanent identity: it must NEVER change,
  so each release's MSI upgrades the previous install in place
  (MajorUpgrade) instead of installing side by side.

  Scope is perUser: the app installs under %LocalAppData%\Programs, so
  neither the first install nor any update needs admin/UAC, and the in-app
  updater can upgrade silently in place. (Switched from perMachine in 1.0.9;
  an existing per-machine copy in Program Files is a different install
  context and must be uninstalled once by hand.)
-->
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:ui="http://wixtoolset.org/schemas/v4/wxs/ui">
  <Package Name="Markdown Studio"
           Manufacturer="Markdown Studio"
           Version="$(var.Version)"
           UpgradeCode="d4a5c1f2-7b3e-4a86-9d2c-1e8f0b6a7c53"
           Scope="perUser"
           Compressed="yes">

    <MajorUpgrade DowngradeErrorMessage="A newer version of Markdown Studio is already installed." />
    <MediaTemplate EmbedCab="yes" />

    <!-- Add/Remove Programs metadata. -->
    <Icon Id="AppIcon.ico" SourceFile="$(var.IconPath)" />
    <Property Id="ARPPRODUCTICON" Value="AppIcon.ico" />
    <Property Id="ARPURLINFOABOUT" Value="https://github.com/TheSaltyKorean/md" />
    <Property Id="ARPHELPLINK" Value="https://github.com/TheSaltyKorean/md/issues" />

    <!-- Minimal wizard: welcome + license + install. -->
    <ui:WixUI Id="WixUI_Minimal" />
    <WixVariable Id="WixUILicenseRtf" Value="$(var.LicenseRtf)" />

    <!-- The whole Flutter Release bundle (exe + data/ + DLLs), harvested
         recursively at build time. Per-user location (%LocalAppData%\Programs\
         Markdown Studio) so no elevation is ever needed. -->
    <StandardDirectory Id="LocalAppDataFolder">
      <Directory Id="ProgramsFolder" Name="Programs">
        <Directory Id="INSTALLFOLDER" Name="Markdown Studio">
          <Files Include="$(var.SourceDir)\**" />
        </Directory>
      </Directory>
    </StandardDirectory>

    <!-- Start-Menu shortcut. The HKCU registry value is the component's
         KeyPath (shortcuts cannot be key paths); it also marks the install
         for the per-user shortcut cleanup on uninstall. -->
    <StandardDirectory Id="ProgramMenuFolder">
      <Component Id="StartMenuShortcut" Guid="8e2f6c1a-0d4b-4f7e-a5c3-2b9d8e0f1a64">
        <Shortcut Id="StartMenuShortcutFile"
                  Name="Markdown Studio"
                  Description="Markdown viewer, WYSIWYG editor and PDF/print studio"
                  Target="[INSTALLFOLDER]markdown_studio.exe"
                  WorkingDirectory="INSTALLFOLDER" />
        <RegistryValue Root="HKCU"
                       Key="Software\MarkdownStudio\Installer"
                       Name="StartMenuShortcut"
                       Type="integer"
                       Value="1"
                       KeyPath="yes" />
      </Component>
    </StandardDirectory>

    <!-- Register .md as a handled file type at install time (per-user → HKCU),
         so the app no longer has to self-register on first run. This mirrors
         the ProgID the runtime FileAssociationService writes
         (MarkdownStudio.md): handler + icon + Open-With entry. We deliberately
         do NOT set the UserChoice default — modern Windows reserves that for
         the user's explicit confirmation. -->
    <Component Id="FileAssociation" Directory="INSTALLFOLDER"
               Guid="b7f4d2e0-9a13-4c58-8e6d-4f1a2c7b0d95">
      <RegistryValue Root="HKCU" Key="Software\Classes\MarkdownStudio.md"
                     Type="string" Value="Markdown Document" />
      <RegistryValue Root="HKCU"
                     Key="Software\Classes\MarkdownStudio.md\DefaultIcon"
                     Type="string" Value="[INSTALLFOLDER]markdown_studio.exe,0" />
      <RegistryValue Root="HKCU"
                     Key="Software\Classes\MarkdownStudio.md\shell\open\command"
                     Type="string"
                     Value="&quot;[INSTALLFOLDER]markdown_studio.exe&quot; &quot;%1&quot;" />
      <RegistryValue Root="HKCU" Key="Software\Classes\.md\OpenWithProgids"
                     Name="MarkdownStudio.md" Type="string" Value=""
                     KeyPath="yes" />
    </Component>
  </Package>
</Wix>
